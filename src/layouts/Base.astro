---
import '../styles/global.css';
import { SITE } from '../config';

interface Props {
  title?: string;
  description?: string;
  /** 'default' = nav completa · 'case-study' = logo + link di ritorno · 'minimal' = solo logo */
  nav?: 'default' | 'case-study' | 'minimal';
  active?: 'pricing';
  /** CTA flottante "Prenota una call" — da spegnere sulle pagine post-vendita */
  floatCta?: boolean;
  /** Pagine operative (es. /benvenuto) da tenere fuori dai motori di ricerca */
  noindex?: boolean;
}

const {
  title = SITE.title,
  description = SITE.description,
  nav = 'default',
  active,
  floatCta = true,
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <nav>
      <div class="wrap nav-inner">
        <a class="logo" href="/">spatalo<span>.</span>tech</a>
        {
          nav === 'case-study' ? (
            <a class="back" href="/#shipped">← Tutti i casi studio</a>
          ) : nav === 'minimal' ? null : (
            <div class="nav-links">
              <a href="/#modello">Come funziona</a>
              <a href="/#confronto">Confronto</a>
              <a href="/#shipped">Showcase</a>
              <a href="/pricing" class:list={[{ 'active-link': active === 'pricing' }]}>Prezzi</a>
              <a class="btn btn-primary" href={SITE.calUrl} target="_blank" rel="noopener">Prenota una call</a>
            </div>
          )
        }
      </div>
    </nav>

    <slot />

    <footer>
      <div class="wrap footer-inner">
        <span>© 2026 {SITE.name}, lo studio di product engineering fondato da {SITE.founder}</span>
        <span>
          <a href={SITE.linkedin} target="_blank" rel="noopener">LinkedIn</a> ·
          <a href={`mailto:${SITE.email}`}>Email</a> ·
          <a href="/termini">Termini</a>
        </span>
      </div>
    </footer>

    {
      floatCta && (
        <a class="float-cta" href={SITE.calUrl} target="_blank" rel="noopener">
          <span class="fc-long">Review gratuita del tuo prodotto.&nbsp;</span>
          <strong>Prenota 30 minuti&nbsp;→</strong>
        </a>
      )
    }

    <script>
      /* ----- scroll reveal ----- */
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          });
        },
        { threshold: 0.15 }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      /* ----- floating CTA ----- */
      const fc = document.querySelector('.float-cta');
      if (fc) {
        const toggle = () => fc.classList.toggle('show', window.scrollY > 480);
        window.addEventListener('scroll', toggle, { passive: true });
        toggle();
      }
    </script>
  </body>
</html>
