---
import Base from '../layouts/Base.astro';
import { SITE, SLOTS } from '../config';

const slotsFree = SLOTS.total - SLOTS.taken;
---

<Base title={`Pricing — ${SITE.title}`} active="pricing">
  <header class="hero wrap">
    <span class="kicker reveal">Pricing</span>
    <h1 class="reveal d1">Due modi di lavorare, prezzi semplici.</h1>
    <p class="sub reveal d2">
      Nessun costo nascosto, nessun conteggio a ore. Scegli il formato che si adatta a come il tuo team vuole muoversi.
    </p>
  </header>

  <section class="plans wrap">
    <div class="plans-grid">
      <!-- ===== 01 · PARTNER ===== -->
      <article class="plan reveal">
        <div class="plan-num">01.</div>
        <h2>Partner</h2>
        <p class="desc">
          Un Senior Product Engineer nel tuo team, in abbonamento. Non eseguo ticket: ragiono sul prodotto, propongo,
          shippo ogni settimana.
        </p>

        <div class="roster">
          <span class="member"><span class="avatar">👨‍💻</span><span>1 Product Engineer<small>senior · 10 anni di esperienza</small></span></span>
          <span class:list={['member', 'slot-chip', { full: slotsFree === 0 }]}>
            <span class="slot-dot"></span>
            {
              slotsFree === 0
                ? 'Slot al completo — lista d’attesa'
                : slotsFree === 1
                  ? 'Ultimo slot disponibile'
                  : `${slotsFree} slot su ${SLOTS.total} disponibili`
            }
          </span>
        </div>

        <div class="tiers">
          <div class="tier">
            <span class="t-label">Mensile<span class="t-note">massima flessibilità</span></span>
            <span class="t-price">2.600€ <small>/mese</small></span>
          </div>
          <div class="tier hot">
            <span class="t-label">Trimestrale<span class="t-note">risparmi 1.200€ e blocchi lo slot</span></span>
            <span class="t-price">2.200€ <small>/mese</small></span>
          </div>
        </div>

        <ul>
          <li><span class="ck">✓</span><span><strong>Senior Product Engineer</strong> dedicato, con oversight su tutto il ciclo di prodotto</span></li>
          <li><span class="ck">✓</span><span><strong>Weekly review</strong>: demo di ciò che è andato in produzione, non slide</span></li>
          <li><span class="ck">✓</span><span>Product discovery, priorità guidate dalle metriche, codice production-ready</span></li>
          <li><span class="ck">✓</span><span><strong>Canale Slack condiviso</strong>, risposta entro 24h lavorative</span></li>
          <li><span class="ck">✓</span><span><strong>Nessun vincolo a lungo termine</strong>: metti in pausa o disdici quando vuoi</span></li>
        </ul>

        <div class="cta-row">
          <a class="btn btn-primary" href={SITE.calUrl} target="_blank" rel="noopener">Inizia con una call conoscitiva</a>
          <p class="guarantee">🛡️<span><strong>Garanzia primo mese:</strong> primo deploy in produzione entro 5 giorni lavorativi — o il primo mese è gratis.</span></p>
        </div>
      </article>

      <!-- ===== 02 · TEAM ===== -->
      <article class="plan reveal d1">
        <div class="plan-num">02.</div>
        <h2>Team</h2>
        <p class="desc">
          Un product team compatto che lavora spalla a spalla con te. Scope definito, prezzo fisso, decisioni vere ogni
          settimana.
        </p>

        <div class="roster">
          <span class="member"><span class="avatar">🧭</span><span>1 Product Manager<small>discovery &amp; priorità</small></span></span>
          <span class="member"><span class="avatar">👨‍💻</span><span>2 Product Engineer<small>design &amp; delivery</small></span></span>
        </div>

        <div class="tiers">
          <div class="tier">
            <span class="t-label">Sprint<span class="t-note">2 settimane, scope definito insieme</span></span>
            <span class="t-price">4.500€ <small>/sprint</small></span>
          </div>
          <div class="tier hot">
            <span class="t-label">Trimestre<span class="t-note">6 sprint consecutivi · risparmi 3.000€</span></span>
            <span class="t-price">24.000€ <small>/trimestre</small></span>
          </div>
        </div>

        <ul>
          <li><span class="ck">✓</span><span><strong>1 Product Manager + 2 Product Engineer</strong> con lead oversight</span></li>
          <li><span class="ck">✓</span><span><strong>Weekly review meeting</strong> con demo e metriche aggiornate</span></li>
          <li><span class="ck">✓</span><span>Product discovery, design system, delivery end-to-end</span></li>
          <li><span class="ck">✓</span><span><strong>Canale Slack condiviso</strong> con tutto il team</span></li>
          <li><span class="ck">✓</span><span><strong>Nessun vincolo a lungo termine</strong>: si rinnova sprint per sprint</span></li>
        </ul>

        <div class="cta-row">
          <a class="btn btn-ghost" href={SITE.calUrl} target="_blank" rel="noopener">Parliamo del tuo progetto</a>
          <p class="guarantee">🛡️<span><strong>Nessun rinnovo automatico:</strong> decidi sprint per sprint, demo alla mano.</span></p>
        </div>
      </article>
    </div>
  </section>

  <!-- ===== extras ===== -->
  <section class="extras wrap">
    <div class="extras-grid">
      <div class="extra-card reveal">
        <div>
          <h3>MVP in 6 settimane</h3>
          <p>Hai solo un'idea? Dalla discovery al primo rilascio in produzione, con metriche dal giorno uno.</p>
        </div>
        <div class="x-price">4.500€<small>/mese</small></div>
      </div>
      <div class="extra-card reveal d1">
        <div>
          <h3>A progetto</h3>
          <p>Scope chiuso e ben definito? Prezzo fisso concordato prima di iniziare, nessuna sorpresa.</p>
        </div>
        <div class="x-price">Scope based<small>preventivo in 48h</small></div>
      </div>
    </div>
  </section>

  <!-- ===== free review banner ===== -->
  <section class="freewrap wrap">
    <div class="freebar reveal">
      <div class="fb-icon">💡</div>
      <div>
        <span class="fb-badge">Free</span>
        <h3>Non sei pronto a impegnarti? Prenota una review gratuita di 30 minuti</h3>
        <p>Una call senza vincoli: esci con insight concreti e azionabili sul tuo prodotto — anche se poi non lavoriamo insieme.</p>
      </div>
      <a class="btn btn-dark" href={SITE.calUrl} target="_blank" rel="noopener">Prenota la review gratuita</a>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="faq wrap">
    <h2 class="reveal">Domande sui prezzi</h2>
    <div class="faq-list reveal d1">
      <details>
        <summary>Come scelgo tra Partner e Team?</summary>
        <p>Partner funziona quando hai già una direzione di prodotto e ti serve seniority per eseguirla bene e in fretta. Team quando serve anche costruire la direzione: discovery, priorità e delivery insieme. Ne parliamo in call e ti dico onestamente quale ha senso — a volte è Partner anche se pensavi Team.</p>
      </details>
      <details>
        <summary>Cosa succede se metto in pausa?</summary>
        <p>Il piano Partner si può mettere in pausa a fine mese: lo slot resta tuo per 30 giorni e i giorni non usati non si pagano. Il piano Team si rinnova sprint per sprint, quindi la pausa è naturale: finisce lo sprint, decidi se farne un altro.</p>
      </details>
      <details>
        <summary>Il trimestrale mi vincola?</summary>
        <p>No: paghi mese per mese anche sul trimestrale. Lo sconto riflette la possibilità di pianificare il lavoro su un orizzonte più lungo. Se interrompi prima, i mesi già fatturati si ricalcolano alla tariffa mensile.</p>
      </details>
      <details>
        <summary>Come funziona la garanzia sul primo mese?</summary>
        <p>Se sei un nuovo cliente sul piano Partner, mi impegno a portare il primo deploy in produzione entro 5 giorni lavorativi dal kickoff. Se non succede, il primo mese non lo paghi. È una garanzia oggettiva: o il codice è in produzione, o non lo è — niente valutazioni soggettive. Dopo il primo mese ti proteggono le pause e la disdetta libere: non resti mai vincolato a un servizio che non ti convince.</p>
      </details>
      <details>
        <summary>Chi possiede il codice e i design?</summary>
        <p>Tu, dal primo giorno. Tutto il codice va nel tuo repository, i design nel tuo workspace. Nessun lock-in: se domani smettiamo di lavorare insieme, hai tutto in casa.</p>
      </details>
      <details>
        <summary>Come funziona la fatturazione?</summary>
        <p>Fattura a inizio periodo (mese o sprint), pagamento a 7 giorni. Tutti i prezzi sono IVA esclusa. Nessun costo di setup, nessun extra non concordato prima.</p>
      </details>
      <details>
        <summary>Lavori con più clienti contemporaneamente?</summary>
        <p>Sul piano Partner tengo al massimo 2 slot attivi, per garantire risposta entro 24h e attenzione vera al prodotto. Per questo gli slot sono limitati e il trimestrale li blocca.</p>
      </details>
    </div>
  </section>

  <div class="wrap">
    <section class="final reveal">
      <h2>Parliamo di cosa dovresti costruire.</h2>
      <p>Call di 30 minuti, senza impegno. Esci con una direzione chiara — anche se poi non lavoriamo insieme.</p>
      <a class="btn btn-accent" href={SITE.calUrl} target="_blank" rel="noopener">Prenota una call</a>
      <p class="note">Tutti i prezzi sono IVA esclusa.</p>
    </section>
  </div>
</Base>

<style>
  /* ---------- hero ---------- */
  header.hero{padding:88px 0 56px;text-align:center}
  .hero .kicker{
    display:inline-block;font-size:13px;font-weight:600;letter-spacing:.12em;
    text-transform:uppercase;color:var(--accent);margin-bottom:18px;
  }
  .hero h1{
    font-size:clamp(38px,5.5vw,60px);line-height:1.06;letter-spacing:-.035em;
    font-weight:700;max-width:720px;margin:0 auto 18px;
  }
  .hero p.sub{color:var(--muted);font-size:18px;max-width:560px;margin:0 auto}

  /* ---------- pricing cards ---------- */
  .plans{padding:24px 0 40px}
  .plans-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}
  @media(max-width:880px){.plans-grid{grid-template-columns:1fr}}

  .plan{
    background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);
    padding:36px 32px;display:flex;flex-direction:column;gap:0;
    transition:box-shadow .25s, transform .25s;
  }
  .plan:hover{box-shadow:0 18px 50px rgba(15,22,38,.08);transform:translateY(-3px)}
  .plan-num{font-size:15px;font-weight:700;color:var(--accent);letter-spacing:.02em;margin-bottom:14px}
  .plan h2{font-size:28px;letter-spacing:-.03em;line-height:1.15;margin-bottom:10px}
  .plan .desc{color:var(--muted);font-size:15.5px;margin-bottom:26px;min-height:72px}
  @media(max-width:880px){.plan .desc{min-height:0}}

  .tiers{border:1px solid var(--line);border-radius:16px;overflow:hidden;margin-bottom:26px}
  .tier{
    display:flex;align-items:baseline;justify-content:space-between;gap:12px;
    padding:16px 18px;background:var(--surface);
  }
  .tier + .tier{border-top:1px solid var(--line)}
  .tier.hot{background:var(--accent-soft)}
  .tier .t-label{font-size:14px;color:var(--muted);font-weight:600}
  .tier.hot .t-label{color:var(--accent)}
  .tier .t-note{display:block;font-weight:400;font-size:12.5px;margin-top:2px}
  .tier .t-price{font-size:22px;font-weight:700;letter-spacing:-.02em;white-space:nowrap}
  .tier .t-price small{font-size:13px;font-weight:500;color:var(--muted)}

  .plan ul{list-style:none;display:flex;flex-direction:column;gap:12px;margin-bottom:30px}
  .plan li{display:flex;gap:11px;font-size:15px;align-items:flex-start}
  .plan li .ck{
    flex:none;width:20px;height:20px;border-radius:50%;
    background:var(--accent-soft);color:var(--accent);
    display:flex;align-items:center;justify-content:center;
    font-size:11px;font-weight:700;margin-top:2.5px;
  }
  .plan li strong{font-weight:650}
  .plan .cta-row{margin-top:auto}
  .plan .cta-row .btn{width:100%;text-align:center}
  .plan .guarantee{
    margin-top:14px;font-size:13px;color:var(--muted);text-align:center;
    display:flex;gap:7px;justify-content:center;align-items:flex-start;
  }
  .plan .guarantee strong{color:var(--ink);font-weight:650}

  /* team roster chips */
  .roster{display:flex;gap:10px;margin-bottom:26px;flex-wrap:wrap}
  .roster .member{
    display:flex;align-items:center;gap:9px;
    border:1px solid var(--line);background:var(--bg);
    border-radius:999px;padding:7px 14px 7px 8px;font-size:13.5px;font-weight:600;
  }
  .roster .avatar{
    width:26px;height:26px;border-radius:50%;flex:none;
    display:flex;align-items:center;justify-content:center;font-size:13px;
    background:var(--accent-soft);
  }
  .roster .member small{display:block;font-weight:500;color:var(--muted);font-size:11.5px;line-height:1.2}
  .roster .slot-chip{background:var(--ok-soft);border-color:transparent;color:var(--ok);padding:7px 14px}
  .roster .slot-chip .slot-dot{width:8px;height:8px;border-radius:50%;background:currentColor;flex:none}
  .roster .slot-chip.full{background:#f7efe0;color:#9a6a1b}

  /* ---------- free review banner ---------- */
  .freewrap{padding:16px 0 72px}
  .freebar{
    background:#f2f1ee;border-radius:var(--radius);
    padding:30px 32px;display:flex;align-items:center;gap:22px;
  }
  .freebar .fb-icon{
    width:54px;height:54px;border-radius:18px;flex:none;
    background:var(--accent-soft);border:2px solid #dbe2ff;
    display:flex;align-items:center;justify-content:center;font-size:25px;
  }
  .fb-badge{
    display:inline-block;font-size:12px;font-weight:700;color:var(--accent);
    border:1.5px solid var(--accent);border-radius:999px;padding:2px 12px;margin-bottom:8px;
  }
  .freebar h3{font-size:20px;letter-spacing:-.02em;margin-bottom:4px}
  .freebar p{color:var(--muted);font-size:14.5px;max-width:560px}
  .freebar .btn-dark{
    margin-left:auto;flex:none;background:var(--ink);color:#fff;
    box-shadow:0 4px 14px rgba(15,22,38,.25);
  }
  .freebar .btn-dark:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(15,22,38,.35)}
  @media(max-width:760px){
    .freebar{flex-direction:column;align-items:flex-start}
    .freebar .btn-dark{margin-left:0}
  }

  /* ---------- extra offers strip ---------- */
  .extras{padding:8px 0 16px}
  .extras-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}
  @media(max-width:880px){.extras-grid{grid-template-columns:1fr}}
  .extra-card{
    border:1px dashed #d6d3cd;border-radius:var(--radius);padding:26px 28px;
    display:flex;align-items:center;justify-content:space-between;gap:20px;
    background:transparent;transition:border-color .2s, background .2s;
  }
  .extra-card:hover{border-color:var(--accent);background:#fff}
  .extra-card h3{font-size:18px;letter-spacing:-.02em;margin-bottom:4px}
  .extra-card p{color:var(--muted);font-size:14px;max-width:420px}
  .extra-card .x-price{font-size:19px;font-weight:700;white-space:nowrap;letter-spacing:-.02em}
  .extra-card .x-price small{display:block;font-size:12px;font-weight:500;color:var(--muted);text-align:right}
  @media(max-width:560px){.extra-card{flex-direction:column;align-items:flex-start}}

  /* ---------- faq ---------- */
  .faq{padding:0 0 88px}
  .faq h2{font-size:clamp(28px,3.5vw,38px);letter-spacing:-.03em;margin-bottom:32px;text-align:center}
  .faq-list{max-width:720px;margin:0 auto;display:flex;flex-direction:column;gap:12px}
  details{
    background:var(--surface);border:1px solid var(--line);border-radius:16px;
    padding:20px 24px;transition:border-color .2s;
  }
  details:hover{border-color:#cfccc5}
  details[open]{border-color:var(--accent)}
  summary{
    cursor:pointer;font-weight:600;font-size:16px;list-style:none;
    display:flex;justify-content:space-between;align-items:center;gap:16px;
  }
  summary::-webkit-details-marker{display:none}
  summary::after{content:"+";font-size:20px;color:var(--muted);transition:transform .2s;flex:none}
  details[open] summary::after{transform:rotate(45deg);color:var(--accent)}
  details p{color:var(--muted);font-size:15px;margin-top:12px;max-width:640px}

  /* ---------- final CTA ---------- */
  .final{
    background:var(--ink);border-radius:var(--radius);color:#fff;
    text-align:center;padding:72px 32px;margin-bottom:32px;
  }
  .final h2{font-size:clamp(30px,4vw,44px);letter-spacing:-.035em;line-height:1.1;margin-bottom:14px}
  .final p{color:#aab2c5;font-size:17px;margin-bottom:30px}
  .final .btn-accent{font-size:16px;padding:15px 30px}
  .final .note{font-size:13px;color:#7a8296;margin:18px 0 0}
</style>
